# ===========================================
# AI CANVAS - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# -------------------------------------------
# 🔴 PHASE 1: Core Foundation
# -------------------------------------------

# Clerk Authentication
# Get from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk URLs (customize these routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/canvas
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/canvas

# Liveblocks Multiplayer
# Get from: https://liveblocks.io/dashboard
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=pk_...
LIVEBLOCKS_SECRET_KEY=sk_...

# -------------------------------------------
# 🟡 PHASE 2: AI & Data
# -------------------------------------------

# Google AI (Gemini 2.5 Pro)
# Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=...

# Pinecone Vector Database
# Get from: https://app.pinecone.io
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=ai-canvas
PINECONE_ENVIRONMENT=us-east-1

# Railway PostgreSQL
# Auto-generated in Railway dashboard
DATABASE_URL=postgresql://...

# Railway Redis
# Auto-generated in Railway dashboard  
REDIS_URL=redis://...

# -------------------------------------------
# 🟡 PHASE 3: Background Jobs & Storage
# -------------------------------------------

# Trigger.dev
# Get from: https://cloud.trigger.dev
TRIGGER_API_KEY=tr_...
TRIGGER_API_URL=https://api.trigger.dev

# Vercel Blob Storage
# Get from: Vercel Dashboard → Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# -------------------------------------------
# 🟢 PHASE 4: Observability & Production
# -------------------------------------------

# Sentry Error Tracking
# Get from: https://sentry.io
SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...

# Helicone AI Observability (optional gateway)
# Get from: https://helicone.ai
HELICONE_API_KEY=sk-helicone-...

# Upstash Rate Limiting
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Meilisearch (self-hosted on Railway)
MEILI_HOST=https://...railway.app
MEILI_MASTER_KEY=...

# -------------------------------------------
# App Configuration
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
